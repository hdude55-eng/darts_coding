<Window x:Class="DartScorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dart Scorer" Height="800" Width="1100">

    <Window.Resources>

        <!-- Center text in DataGrid cells -->
        <Style x:Key="CenterCellText" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

    </Window.Resources>
    
    <TabControl>

        <!-- TAB 1: SCOREBOARD -->
        <TabItem Header="Game">
            <Grid>
                
                <Grid Margin="10" Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Background="#2D2D30" >
            <TextBlock Text="501" FontSize="44" Foreground="White" Margin="10"/>

                        <ComboBox x:Name="PlayerSelector" FontSize="30" Width="300" VerticalAlignment="Center" Margin="10" SelectionChanged="PlayerSelector_SelectionChanged"/>

            <TextBlock Text="Value:" Foreground="White" FontSize="44" VerticalAlignment="Center"/>
            <TextBlock x:Name="CurrentValue" FontSize="48" VerticalAlignment="Center" Foreground="Red" Margin="10"/>

            <StackPanel Orientation="Horizontal" Margin="20">
                <RadioButton x:Name="SingleBtn" Content="Single" FontSize="28" Foreground="LawnGreen" IsChecked="True"
                             Checked="Multiplier_Changed">
                    <RadioButton.LayoutTransform>
                        <ScaleTransform ScaleX="2.0" ScaleY="2.0"/>
                    </RadioButton.LayoutTransform>
                </RadioButton>
                             
                <RadioButton x:Name="DoubleBtn" Content="Double" FontSize="28" Foreground="Yellow" Margin="10,0"
                             Checked="Multiplier_Changed">
                    <RadioButton.LayoutTransform>
                        <ScaleTransform ScaleX="2.0" ScaleY="2.0"/>
                    </RadioButton.LayoutTransform>
                </RadioButton>
                
                <RadioButton x:Name="TripleBtn" Content="Triple" FontSize="28" Foreground="Red" 
                             Checked="Multiplier_Changed">
                    <RadioButton.LayoutTransform>
                        <ScaleTransform ScaleX="2.0" ScaleY="2.0"/>
                    </RadioButton.LayoutTransform>
                </RadioButton>
            </StackPanel>
        </StackPanel>

        <!-- Multiplier + Dart selection -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="10">
            <!--   <TextBlock Text="A:" Foreground="White" FontSize="44" VerticalAlignment="Center"/>
            <TextBlock x:Name="val1" FontSize="44" Foreground="Yellow" Margin="10"/>
            <TextBlock Text="B:" Foreground="White" FontSize="44" VerticalAlignment="Center"/>
            <TextBlock x:Name="val2" FontSize="44" Foreground="Yellow" Margin="10"/>
            <TextBlock Text="C:" Foreground="White" FontSize="44" VerticalAlignment="Center"/>
            <TextBlock x:Name="val3" FontSize="44" Foreground="Yellow" Margin="10"/> -->
            <!-- Multiplier -->

            <!-- Dart -->
            <StackPanel Orientation="Horizontal" Margin="20,0">
                <RadioButton x:Name="Dart1Btn" Content="1st Dart" FontSize="14" Foreground="AntiqueWhite" IsChecked="True">
                    <RadioButton.LayoutTransform>
                        <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                    </RadioButton.LayoutTransform>
                </RadioButton>
                <RadioButton x:Name="Dart2Btn" Content="2nd Dart" FontSize="14" Foreground="AntiqueWhite" Margin="10,0">
                    <RadioButton.LayoutTransform>
                        <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                    </RadioButton.LayoutTransform>
                </RadioButton>
                <RadioButton x:Name="Dart3Btn" Content="3rd Dart" FontSize="14" Foreground="AntiqueWhite">
                    <RadioButton.LayoutTransform>
                        <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                    </RadioButton.LayoutTransform>
                </RadioButton>
            </StackPanel>

            <Button Content="Enter Value" Width="150" Margin="20,0" FontSize="20" Click="Enter_Click"/>
        </StackPanel>

        <!-- Player Table -->
        <DataGrid x:Name="ScoreGrid" Grid.Row="2" AutoGenerateColumns="False"
          Background="#1E1E1E"
          Foreground="White"
          FontSize="20" 
          RowBackground="#2D2D30"
          AlternatingRowBackground="DarkOliveGreen"
          GridLinesVisibility="None"
          Height="150" >
          <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                   <Setter Property="Foreground" Value="Black"/>
                   <Setter Property="FontWeight" Value="Bold"/>
                   <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
          </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Player" Binding="{Binding PlayerName}"/>

                            <!-- CURRENT TURN -->
                            <DataGridTextColumn Header="Turn" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding GameNumber}"/>
                            <DataGridTextColumn Header="Dart1" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding Dart1}"/>
                            <DataGridTextColumn Header="Dart2" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding Dart2}"/>
                            <DataGridTextColumn Header="Dart3" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding Dart3}"/>
                            <DataGridTextColumn Header="Throw Total" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding Total}"/>

                            <!-- SPACER -->
                            <DataGridTextColumn Header="" Width="30"/>

                            <!-- PREVIOUS TURN -->
                            <DataGridTextColumn Header="Prev Turn" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding PrevGameNumber}"/>
                            <DataGridTextColumn Header="Prev Dart1" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding PrevDart1}"/>
                            <DataGridTextColumn Header="Prev Dart2" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding PrevDart2}"/>
                            <DataGridTextColumn Header="Prev Dart3" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding PrevDart3}"/>
                            <DataGridTextColumn Header="Prev Total" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding PrevTotal}"/>

                            <!-- SPACER -->
                            <DataGridTextColumn Header="" Width="30"/>
                            
                            <!-- REMAINING -->
                            <DataGridTextColumn Header="REMAINING" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding Remaining}"/>
                        </DataGrid.Columns>
        </DataGrid>
            
                        <!-- Number Buttons -->
        <UniformGrid Grid.Row="3" Columns="7">
            <Button Content="20" FontSize="50" Click="Score_Click"/>
            <Button Content="19" FontSize="50" Click="Score_Click"/>
            <Button Content="18" FontSize="50" Click="Score_Click"/>
            <Button Content="17" FontSize="50" Click="Score_Click"/>
            <Button Content="16" FontSize="50" Click="Score_Click"/>

            <Button Content="15" FontSize="50" Click="Score_Click"/>
            <Button Content="14" FontSize="50" Click="Score_Click"/>
            <Button Content="13" FontSize="50" Click="Score_Click"/>
            <Button Content="12" FontSize="50" Click="Score_Click"/>
            <Button Content="11" FontSize="50" Click="Score_Click"/>

            <Button Content="10" FontSize="50" Click="Score_Click"/>
            <Button Content="9" FontSize="50" Click="Score_Click"/>
            <Button Content="8" FontSize="50" Click="Score_Click"/>
            <Button Content="7" FontSize="50" Click="Score_Click"/>
            <Button Content="6" FontSize="50" Click="Score_Click"/>

            <Button Content="5" FontSize="50" Click="Score_Click"/>
            <Button Content="4" FontSize="50" Click="Score_Click"/>
            <Button Content="3" FontSize="50" Click="Score_Click"/>
            <Button Content="2" FontSize="50" Click="Score_Click"/>
            <Button Content="1" FontSize="50" Click="Score_Click"/>

            <Button Content="Bull" FontSize="50" Click="Score_Click"/>
            <Button Content="Miss" FontSize="50" Click="Miss_Click"/>
            <Button Content="???" FontSize="40"/>
            <Button Content="Players" FontSize="40" Click="SetPlayers_Click"/>
            <Button Content="Game" FontSize="40" Click="NewGame_Click"/>
            <Button Content="???" FontSize="40"/>
            <Button Content="Save" FontSize="40" Click="Export_Click"/>
            <Button Content="???" FontSize="40"/>
        </UniformGrid>

    </Grid>

            </Grid>
        </TabItem>

        <!-- TAB 2: HISTORY -->
        <TabItem Header="History">
            <Grid Margin="10">

                <DataGrid x:Name="HistoryGrid"
                      AutoGenerateColumns="False"
                      FontSize="50" 
                      Background="#1E1E1E"
                      Foreground="White"
                      RowBackground="#2D2D30"
                      AlternatingRowBackground="DarkOliveGreen">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Player" Binding="{Binding PlayerName}"/>
                        <DataGridTextColumn Header="Game" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding GameNumber}"/>
                        <DataGridTextColumn Header="Dart1" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding Dart1}"/>
                        <DataGridTextColumn Header="Dart2" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding Dart2}"/>
                        <DataGridTextColumn Header="Dart3" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding Dart3}"/>
                        <DataGridTextColumn Header="Total" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding Total}"/>
                        <DataGridTextColumn Header="Remaining" Foreground="Yellow" ElementStyle="{StaticResource CenterCellText}" Binding="{Binding Remaining}"/>
                    </DataGrid.Columns>

                </DataGrid>

            </Grid>
        </TabItem>

    </TabControl>
    
</Window>
