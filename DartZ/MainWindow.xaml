<Window x:Class="DartScorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dart Scorer" Height="500" Width="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <!-- Score Display -->
        <TextBlock x:Name="ScoreText"
                   Text="501"
                   FontSize="60"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <!-- Buttons -->
        <UniformGrid Grid.Row="1" Columns="5">
            <Button Content="20" FontSize="30" Click="Score_Click"/>
            <Button Content="19" FontSize="30" Click="Score_Click"/>
            <Button Content="18" FontSize="30" Click="Score_Click"/>
            <Button Content="17" FontSize="30" Click="Score_Click"/>
            <Button Content="16" FontSize="30" Click="Score_Click"/>
            <Button Content="15" FontSize="30" Click="Score_Click"/>
            <Button Content="14" FontSize="30" Click="Score_Click"/>
            <Button Content="13" FontSize="30" Click="Score_Click"/>
            <Button Content="12" FontSize="30" Click="Score_Click"/>
            <Button Content="11" FontSize="30" Click="Score_Click"/>
            <Button Content="10" FontSize="30" Click="Score_Click"/>
            <Button Content="9" FontSize="30" Click="Score_Click"/>
            <Button Content="8" FontSize="30" Click="Score_Click"/>
            <Button Content="7" FontSize="30" Click="Score_Click"/>
            <Button Content="8" FontSize="30" Click="Score_Click"/>
            <Button Content="6" FontSize="30" Click="Score_Click"/>
            <Button Content="5" FontSize="30" Click="Score_Click"/>
            <Button Content="4" FontSize="30" Click="Score_Click"/>
            <Button Content="3" FontSize="30" Click="Score_Click"/>
            <Button Content="2" FontSize="30" Click="Score_Click"/>
            <Button Content="1" FontSize="30" Click="Score_Click"/>

            <Button Content="Red Bull" FontSize="20" Click="Score_Click"/>
            <Button Content="Green Bull" FontSize="20" Click="Score_Click"/>
            <Button Content="Miss" FontSize="30" Click="Score_Click"/>
            <Button Content="Enter" FontSize="30" Click="Score_Click"/>
        </UniformGrid>
    </Grid>
</Window>
